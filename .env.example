# Compose environment for the KAM stack. Copy to `.env` and edit as needed.
#
# Postgres + Keto values are interpolated into docker-compose.yml (${VAR}).
# KAM_* values are passed into the kam container via env_file. The Go binary
# does NOT auto-load this file; for host-only runs export these or use localhost
# targets (KAM_KETO_*=localhost:4466/4467, KAM_DATABASE_URL=...@localhost:5432).

# ── Postgres ───────────────────────────────────────────────────────────
POSTGRES_USER=kam
POSTGRES_PASSWORD=kam
POSTGRES_DB=kam

# ── Keto (DSN points at the separate `keto` database) ──────────────────
KETO_DSN=postgres://kam:kam@postgres:5432/keto?sslmode=disable

# ── KAM Go service (in-network targets) ────────────────────────────────
KAM_HTTP_ADDR=:8080
KAM_DATABASE_URL=postgres://kam:kam@postgres:5432/kam?sslmode=disable
KAM_KETO_READ_URL=keto:4466
KAM_KETO_WRITE_URL=keto:4467
